{
  "name": "multilingual-translation-ai",
  "version": "1.0.0",
  "description": "Real-time translation service for Multilingual Mandi chat-based marketplace",
  "main": "index.js",
  "scripts": {
    "start": "node index.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "dev": "nodemon index.js"
  },
  "keywords": [
    "translation",
    "multilingual",
    "ai",
    "indian-languages",
    "chat",
    "marketplace"
  ],
  "author": "Multilingual Mandi Team",
  "license": "MIT",
  "dependencies": {
    "express": "^4.18.2",
    "axios": "^1.6.0",
    "langdetect": "^0.2.1",
    "winston": "^3.11.0",
    "crypto": "^1.0.1"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "fast-check": "^3.15.0",
    "nodemon": "^3.0.2",
    "supertest": "^6.3.3"
  },
  "jest": {
    "testEnvironment": "node",
    "collectCoverageFrom": [
      "src/**/*.js",
      "!src/**/*.test.js"
    ],
    "testMatch": [
      "**/__tests__/**/*.js",
      "**/?(*.)+(spec|test).js"
    ]
  }
}